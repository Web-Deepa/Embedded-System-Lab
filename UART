

#include <avr/io.h>
#define F_CPU 16000000
#include <util/delay.h>
void uart_init(void){
	UCSRB=(1<<TXEN);
	UCSRC=(1<<UCSZ1)|(1<<UCSZ0)|(1<<URSEL);
	UBRRL=0X33;
}
void uart_send(char ch){
	while(!(UCSRA &(1<<UDRE)));
	UDR=ch;
}

int main(void)
{
   char str[]="Embedded System" ;
   uart_init();
      while (1) 
    {
		for(int i=0;str[i]!='\0';i++)
		{
			uart_send(str[i]);
    }
	_delay_ms(1000);
	}
	return 0;
}

